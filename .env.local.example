# ---------------------------------------------------------------------------
# Configuració de l'aplicació de la piscina comunitària
# Copia aquest fitxer a ".env.local" i omple els valors reals.
# ---------------------------------------------------------------------------

# URL i clau pública (anon) del teu projecte de Supabase
# Les trobaràs a: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://EL-TEU-PROJECTE.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=la-teva-clau-anon

# Clau de servei (service role) de Supabase. NOMÉS al servidor; mai al navegador.
# La fa servir la tasca programada de recordatoris per llegir controls i usuaris.
# La trobaràs a: Supabase > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=la-teva-clau-service-role

# Secret compartit que protegeix la ruta /api/cron/reminder.
# Posa el mateix valor a la tasca de pg_cron (migració 0004).
CRON_SECRET=un-secret-llarg-i-aleatori

# URL pública del lloc (per als enllaços màgics del correu).
# En local: http://localhost:3000 ; en producció: https://el-teu-domini.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Alertes per correu (Resend) ---
# Opcional: si no es configura, l'app funciona igualment però NO enviarà
# correus d'alerta (només els registrarà a la consola del servidor).
# Aconsegueix la clau a https://resend.com (pla gratuït disponible).
RESEND_API_KEY=
# Adreça remitent verificada a Resend. Per provar pots usar onboarding@resend.dev
ALERT_FROM_EMAIL=Piscina Comunitària <onboarding@resend.dev>
